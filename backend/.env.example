# HTTP listen address
HTTP_ADDR=:3000

# Postgres connection string — required, server will not start without it
DATABASE_URL=

# JWT signing key for access tokens — generate with: openssl rand -hex 32
JWT_SECRET=

# Cookie signing key for refresh tokens — generate with: openssl rand -hex 32
SESSION_SECRET=

# Frontend origin for CORS and redirects
FRONTEND_URL=http://localhost:5173
