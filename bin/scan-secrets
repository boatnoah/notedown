#!/usr/bin/env bash
# Scan for secrets before opening a PR.
# Checks staged changes + every commit on this branch since it diverged from main.
set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
  echo "gitleaks not found — installing via Homebrew..."
  if command -v brew &>/dev/null; then
    brew install gitleaks
  else
    echo "Homebrew not found. Install gitleaks manually: https://github.com/gitleaks/gitleaks"
    exit 1
  fi
fi

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

PASS=0
FAIL=0

run() {
  local label="$1"; shift
  echo "  scanning $label..."
  if gitleaks "$@" 2>&1 | sed 's/^/    /'; then
    echo "  ✓ $label"
    ((PASS++))
  else
    echo "  ✗ $label — secrets detected, do not push"
    ((FAIL++))
  fi
  echo
}

BASE="$(git merge-base HEAD origin/main 2>/dev/null || git merge-base HEAD main)"

echo
echo "▶ secrets scan"
run "staged changes"    detect --staged --source .
run "branch commits"    git     --log-opts="${BASE}..HEAD"

echo "----------------------------------------"
printf "  passed: %d  failed: %d\n\n" "$PASS" "$FAIL"

[ "$FAIL" -eq 0 ]
